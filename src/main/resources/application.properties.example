spring.application.name=kaasu-creator
# Render sets PORT automatically; fallback to 9093 for local dev
server.port=${PORT:9093}

# ── Supabase PostgreSQL ──────────────────────────────────────────
# Provide these via environment variables. Never commit real credentials.
# Pooler (Session mode, IPv4, all JDBC features work):
#   host: aws-1-<region>.pooler.supabase.com  port: 5432  user: postgres.<project-ref>
spring.datasource.url=${DATABASE_URL:jdbc:postgresql://localhost:5432/postgres?sslmode=require}
spring.datasource.username=${DATABASE_USERNAME:postgres}
spring.datasource.password=${DATABASE_PASSWORD:changeme}
spring.datasource.driver-class-name=org.postgresql.Driver

# Connection Pool — tuned for Supabase free tier (pauses after inactivity)
spring.datasource.hikari.maximum-pool-size=5
spring.datasource.hikari.minimum-idle=1
spring.datasource.hikari.initialization-fail-timeout=-1
spring.datasource.hikari.connection-timeout=8000
spring.datasource.hikari.keepalive-time=60000
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.max-lifetime=1800000

# Disable Spring Boot's auto SQL initialization (DatabaseInitializer handles it)
spring.sql.init.mode=never

# Thymeleaf — cache off in dev, Render sets THYMELEAF_CACHE=true via env
spring.thymeleaf.cache=${THYMELEAF_CACHE:false}

# Gemini AI API — get a free key at https://aistudio.google.com
gemini.api.key=${GEMINI_API_KEY:}
